{
  "uid": "nemo-money-paths",
  "title": "Nemo — Money Paths",
  "tags": ["nemo", "business"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {
      "id": 1, "type": "stat", "title": "GL unbalanced entries",
      "description": "POSTED journal entries with debits != credits. Must be 0.",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "max(nemo_gl_unbalanced_entries)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "thresholds": {"mode": "absolute", "steps": [
        {"color": "#2FA893", "value": null}, {"color": "#F4523F", "value": 1}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 2, "type": "stat", "title": "Dead outbox events",
      "description": "Money-path events permanently undelivered (all services).",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "sum(nemo_outbox_dead_events)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "thresholds": {"mode": "absolute", "steps": [
        {"color": "#2FA893", "value": null}, {"color": "#F4523F", "value": 1}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 3, "type": "stat", "title": "Payments stuck >1h",
      "description": "PENDING/PROCESSING for over an hour — customer money in limbo.",
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "max(nemo_payments_stuck_processing)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "thresholds": {"mode": "absolute", "steps": [
        {"color": "#2FA893", "value": null}, {"color": "#F4523F", "value": 1}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 4, "type": "stat", "title": "Payment success rate (24h)",
      "description": "completed / (completed + failed) over the trailing 24h.",
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "max(nemo_payments_completed_24h) / clamp_min(max(nemo_payments_completed_24h) + max(nemo_payments_failed_24h), 1)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [
        {"color": "#F4523F", "value": null}, {"color": "#2FA893", "value": 0.95}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 5, "type": "timeseries", "title": "Outbox oldest pending age by service",
      "description": "Age of the oldest unpublished event. Healthy relays hold this near zero; the alert fires at 300s.",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 5},
      "targets": [{"expr": "nemo_outbox_oldest_pending_age_seconds", "legendFormat": "{{job}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"lineWidth": 2, "fillOpacity": 0, "pointSize": 4}},
        "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 6, "type": "timeseries", "title": "Payment outcomes (trailing 24h counts)",
      "description": "Completed vs failed; the success-rate tile summarizes the same pair.",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 5},
      "targets": [
        {"expr": "max(nemo_payments_completed_24h)", "legendFormat": "completed", "refId": "A"},
        {"expr": "max(nemo_payments_failed_24h)", "legendFormat": "failed", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "none", "custom": {"lineWidth": 2, "fillOpacity": 0, "pointSize": 4}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "completed"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#2FA893"}}]},
          {"matcher": {"id": "byName", "options": "failed"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#F4523F"}}]}
        ]},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 7, "type": "timeseries", "title": "Journal entries posted (trailing 24h)",
      "description": "Ledger flow heartbeat — a flatline at zero means consumers are stalled.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "targets": [{"expr": "max(nemo_gl_entries_posted_24h)", "legendFormat": "entries posted (24h window)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "custom": {"lineWidth": 2, "fillOpacity": 0, "pointSize": 4}}, "overrides": []},
      "options": {"legend": {"showLegend": false}, "tooltip": {"mode": "single"}}
    },
    {
      "id": 8, "type": "timeseries", "title": "Outbox pending backlog by service",
      "description": "Undispatched rows; sustained growth means the relay is not keeping up.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "targets": [{"expr": "nemo_outbox_pending_events", "legendFormat": "{{job}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "custom": {"lineWidth": 2, "fillOpacity": 0, "pointSize": 4}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    }
  ]
}
